<EntryField>: #MDTextField
    id: label
    font_style: "Label"
    mode: "filled"
    theme_bg_color: 'Custom'
    fill_color_normal: app.theme_cls.surfaceContainerLowColor
    fill_color_focus: app.theme_cls.surfaceContainerHighColor
    theme_font_name: 'Custom'
    font_name: 'CH'
    height: root.standard_height
    MDTextFieldHintText:
        text: root.hint

<Property>:
    standard_height: 130

<EntryFieldWithIcon>: #MDBoxLayout
    label: label
    adaptive_height: True
    padding: 0,0,0,0

    EntryField:
        id: label
        text: root.text
        role: root.role
        hint: root.hint
        is_correct: root.is_correct
        allow_empty: root.allow_empty

    MDIconButton:
        size_hint_y: 1
        size_hint_x: None
        width: self.height*0.7
        radius: 0
        allow_hover: False
        ripple_effect: False
        icon: root.icon
        on_release: root.press_button()
        
