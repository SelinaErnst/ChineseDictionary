#     MakeDecision:
#         accept_func: root.accept_func



<Options>: #MDBoxLayout
    rv_scroll: rv_scroll
    size_hint_y: None
    itemclass: 'MyListItem'
    height: max(root.min_h,min(root.max_h, scroll.minimum_height))

    MDRecycleView:
        id: rv_scroll
        viewclass: root.itemclass
        RecycleBoxLayout:
            id: scroll
            orientation: "vertical"
            size_hint: 1, None
            height: self.minimum_height
            default_size_hint: 1, None
            default_height: None
            spacing: 10

<MakeSimpleDecision>: #MDBoxLayout
    orientation: 'vertical'
    adaptive_height: True
    MDDivider:
    MDBoxLayout:
        padding: 0,40,0,0
        adaptive_height: True
        Widget:
        MyIconButton:
            radius: 20
            size_hint: None, None
            size: root.button_width, root.button_width
            icon: root.deny_icon
            style: "elevated"
            on_release: 
                app.dismiss_all()
                root.deny_func() if root.deny_func!=None else None
        Widget:
        MyIconButton:
            radius: 20
            size_hint: None, None
            size: root.button_width, root.button_width
            icon: root.confirm_icon
            style: "elevated"
            on_release: 
                app.dismiss_all()
                root.accept_func() if root.accept_func!=None else None
        Widget:

<MakeDecision>: #MDBoxLayout
    orientation: 'vertical'
    adaptive_height: True
    MDDivider:
    MDBoxLayout:
        padding: 0,40,0,0
        adaptive_height: True
        # Widget:
        RigidIconTextButton:
            width: root.button_width
            icon: root.deny_icon
            text: root.deny_text
            style: "elevated"
            on_release: 
                app.dismiss_all()
                root.deny_func() if root.deny_func!=None else None
        Widget:
        RigidIconTextButton:
            width: root.button_width
            icon: root.confirm_icon
            text: root.confirm_text
            style: "elevated"
            on_release: 
                app.dismiss_all()
                root.accept_func() if root.accept_func!=None else None
        # Widget:

<SimpleClose>
    icon: 'close'
    adaptive_height: True
    orientation: 'vertical'
    MDDivider:
    MDBoxLayout:
        padding: 0,40,0,0
        adaptive_height: True
        Widget:
        MyIconButton:
            icon: root.icon
            on_release: app.dismiss_all()
            style: 'elevated'