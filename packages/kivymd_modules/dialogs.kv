<CustomDialog>:
    support: support
    content: content
    decision: decision
    padding: 40
    md_bg_color: [0, 0, 0, 0.7]

    title: 'TITLE'
    support_text: ''
    dialog_padding: 40,40
    dialog_width: None
    box_pos: {'center_x': .5,'center_y': 0.5}

    title_font_style: 'Title'
    title_font_role: 'large'


    MDBoxLayout:
        id: box
        radius: 20
        pos_hint: root.box_pos
        md_bg_color: app.theme_cls.surfaceContainerColor
        padding: root.dialog_padding
        orientation: 'vertical'
        adaptive_height: True
        size_hint_x: None
        width: root.width-(2*root.padding) if root.dialog_width==None else root.dialog_width
        MultiLineLabel:
            id: title_label
            text: root.title
            font_style: root.title_font_style
            role: root.title_font_role
            halign: 'center'
        MDDivider:
        MultiLineLabel:
            id: support
            text: root.support_text
            padding: (0,10,0,10) if self.text!="" else (0,0,0,10)
            label_padding: 0,50,0,50
        MDBoxLayout:
            id: content
            adaptive_height: True
            orientation: 'vertical'
        MDBoxLayout:
            id: decision
            adaptive_height: True
            orientation: 'vertical'
            # md_bg_color: 'red'

<GrantAccess>: #CustomDialog
    title: 'Grant Access To Storage'
    accept_func:  root.permissions_external_storage
    deny_func:  root.permission_denied
    confirm_text: 'Accept'
    deny_text: 'Return'
    dialog_width: 850

<ChooseAppDirectory>: #CustomDialog
    title: 'Choose Location for App Documents'
    support_text: 'This app uses a chosen directory to store dictionaries and user settings.'
    accept_func:  root.save_app_dir
    deny_func:  root.save_default_app_dir

<ShowPaletteOptions>: #CustomDialog
    title: 'Primary Palette'
    dialog_padding: 10,40

<AddElement>: #CustomDialog
    box_pos: {'center_x': .5,'center_y': 0.7}

<ConfirmUnsaved>: #CustomDialog
    # MakeDecision:
    accept_func: root.save_changes
    deny_func: root.continue_to_next_screen
    dialog_width: 850

<ConfirmDelete>: #CustomDialog
    title: 'Delete\n'+root.name
    dialog_width: 850

<ConfirmExport>: #CustomDialog
    title: 'Export\n'+root.name
    dialog_width: 850


<MyDialog>: #MDDialog
    radius: 20,20,20,20   
    MDDialogHeadlineText:
        text: root.title 
    MDDialogSupportingText:
        text: root.support_text
        halign: 'left'
#         role: 'small'


# <ConfirmExport>: #MDDialog
