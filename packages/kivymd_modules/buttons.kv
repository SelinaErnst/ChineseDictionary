
# = ============================================================== = #
# =                          ICON AND TEXT                         = #
# = ============================================================== = #

<MyIconTextButton>: #MDButton
    radius: 20
    height: self.ids.label.texture_size[1] #based on padding
    font_style: 'Label'
    role: 'large'
    icon_size: None
    padding: 30

    MDButtonIcon: 
        pos_hint: {'x': 0,'center_y': 0.5}
        id: icon
        icon: root.icon
        padding: root.padding,root.padding,20,root.padding
        font_size: self.font_size if root.icon_size==None else root.icon_size
    MDButtonText: 
        id: label
        text: root.text
        pos_hint: {'right': 1,'center_y': 0.5}
        padding: 0,root.padding,root.padding+40,root.padding
        font_style: root.font_style
        role: root.role
    
<RigidIconTextButton>: #MyIconTextButton
    theme_width: "Custom"

<MultiLineIconTextButton>: #MyIconTextButton
    theme_width: "Custom" 
    width: (self.ids.icon.texture_size[0]+self.ids.label.texture_size[0])

# used with Interface
<NavigationButton>:  #MDButton
    radius: 20
    theme_width: "Custom"
    size_hint_x: 1
    style: 'text'
    MDButtonIcon: 
        icon: root.icon
    MDButtonText: 
        text: root.text
        role: 'large'
        padding: 50

# = ============================================================== = #
# =                            ONLY TEXT                           = #
# = ============================================================== = #

<MyTextButton>: #MDButton
    radius: 20
    height: self.ids.label.texture_size[1]
    MDButtonText:
        id: label
        text: root.text
        pos_hint: {'center_x': 0.5,'center_y': 0.5}
        adaptive_width: True
        padding: root.padding
        font_style: root.font_style
        role: root.role

<RigidTextButton>: #MyTextButton
    theme_width: "Custom"

<FlexTextButton>: #MyTextButton
    theme_width: "Custom"
    width: self.ids.label.texture_size[0]

# = ============================================================== = #
# =                              ICON                              = #
# = ============================================================== = #

<MyIconButton>: #MDButton
    theme_width: "Custom"
    size: self.size
    radius: 20
    pos_hint: {'center_x': 0.5,'center_y': 0.5}
    MDButtonIcon:
        icon: root.icon
        pos_hint: {'center_x': 0.5,'center_y': 0.5}
        theme_font_size: 'Custom'
        font_size: sorted(root.size)[0] - 20