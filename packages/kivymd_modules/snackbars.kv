

<ErrorMsg>:
    radius: 20,20,0,0
    md_bg_color: root.theme_cls.onErrorContainerColor
    orientation: "horizontal"
    MDSnackbarText:
        text: root.error
        theme_text_color: "Custom"
        text_color: root.theme_cls.onErrorColor
        max_lines: 3
    MDSnackbarSupportingText: 
        text: root.msg 
        theme_text_color: "Custom"
        text_color: root.theme_cls.onErrorColor
        style: "Label"
        role: "small"
    MDSnackbarCloseButton:
        pos_hint: {"center_x": 0.5}
        icon: "close"
        text_color: root.theme_cls.onErrorColor
        on_release: root.dismiss()

<AttentionMsg>:
    radius: 20,20,0,0
    orientation: "horizontal"
    MDSnackbarText:
        text: root.attention
        max_lines: 3
    MDSnackbarSupportingText: 
        text: root.msg 
        style: "Label"
        role: "small"
    MDSnackbarCloseButton:
        pos_hint: {"center_x": 0.5}
        icon: "close"
        on_release: root.dismiss()