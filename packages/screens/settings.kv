
<Settings>: #MyScreen
    MDBoxLayout:
        orientation: 'vertical'
        MDStackLayout:
            # orientation: 'vertical'
            spacing: 50
            padding: 50, 50
            Setting:
                id: theme_style
                hint: 'Theme Style'
                text:  app.theme_cls.theme_style
                icon: 'theme-light-dark'    
                press_button: self.switch_theme
            Setting:
                id: palette
                icon: 'palette'
                hint: 'Palette'
                text:  app.theme_cls.primary_palette
                press_button: self.show_options
                options: self.get_palettes()
            Setting:
                id: app_directory
                setting: 'app_directory'
                hint: 'App Directory'
                text: app.get_setting('app_directory',default=True)
                icon: 'folder-open'
                press_button: self.choose_directory
            Setting:
                id: import_directory
                setting: 'import_directory'
                hint: 'Import Directory'
                text: app.get_setting('import_directory')
                icon: 'folder-open'
                press_button: self.choose_directory
            MDStackLayout:
                adaptive_height: True
                spacing: 50
                MultiLineIconTextButton:
                    text: 'Template'
                    icon: 'pencil'
                    on_release: root.open_file(app.get_setting('pleco_template'))
                MultiLineIconTextButton:
                    text: 'Categories'
                    icon: 'pencil'
                    on_release: root.open_file(app._MyApp__appdata+'defaults/'+'dictionary_categories.json')
            MultiLineIconTextButton:
                text: 'Reset Settings'
                icon: 'backup-restore'
                on_release: app.reset_settings()

        BottomFieldButton:
            text: 'Save'
            style: 'filled'
            press_button: root.save_settings

<ShowFileContent>:
    input: input
    anchor_y: 'bottom'
    TextInput:
        id: input
        text: root.text
        font_size: sp(11)

    BottomFieldButton:
        text: 'Save'
        style: 'elevated'
        press_button: root.change_file    