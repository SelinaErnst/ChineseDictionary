
<ViewDict>:
    rv_scroll: rv_scroll
    grid: grid
    bottom_nav: bottom_nav
    search_entry: search_entry
    filter: filter
    MDAnchorLayout:
        padding: 25,50,25,50
        MDBoxLayout:
            orientation: 'vertical'
            MDBoxLayout:
                adaptive_height: True
                orientation: 'vertical'
                TitleLabelsWithIcon:
                    # md_bg_color: 'white'
                    anchor_x: "left"
                    left_text: root.dict_name
                    right_text: str(root.entry_count)
                    role: 'large'
                    icon: 'magnify'
                    press_button: root.toggle_search_bar
                MDBoxLayout:
                    id: filter
                    size_hint_y: None
                    height: search_entry.height + 2*20
                    orientation: 'vertical'
                    padding: 0,20,0,20
                    MDTextField:
                        id: search_entry
                        theme_font_name: "Custom"
                        font_name:"CH"
                        on_text: root.set_list_items(self.text,True)
                # MDStackLayout:
                #     adaptive_height: True
                #     CommonAssistChip: 
                #         text: "translated"
                #         icon: "translate"
                #     CommonAssistChip: 
                #         text: "radical"
                #         icon: "alpha-r-box"
                #     CommonAssistChip: 
                #         text: "measure word"
                #         icon: "scale-unbalanced"
                #     CommonAssistChip: 
                #         text: "grammatical"
                #         icon: "bookshelf"
            MDRecycleView:
                id: rv_scroll
                viewclass: 'DictionaryItem'
                RecycleBoxLayout:
                    id: grid
                    orientation: "vertical"
                    spacing: 10
                    size_hint: 1, None
                    height: self.minimum_height
                    default_size_hint: 1, None
                    default_height: 2*(1.75*60+10)+2*20

    MDBottomSheet:
        id: bottom_nav
        size_hint_y: None
        height: 170
        sheet_type: "standard"

        BottomSheetDragHandleContainer:
            padding: 20
            MDAnchorLayout:
                anchor_x: 'center'
                anchor_y: 'center'
                size_hint_y: None
                height: bottom_nav.height-2*20
                MDBoxLayout:
                    orientation: 'horizontal'
                    adaptive_width: True
                    size_hint_y: None
                    height: self.parent.height
                    spacing: 50
                    MyIconButton:
                        text: 'Add'
                        icon: 'plus'
                        size: self.parent.height, self.parent.height
                        style: 'text'
                        on_release: root.add_character()
                    MyIconButton:
                        text: 'Sort'
                        icon: 'sort'
                        size: self.parent.height, self.parent.height
                        style: 'text'
                        on_release: root.get_sorting_key()
                    MyIconButton:
                        text: 'Rename'
                        icon: 'pencil'
                        style: 'text'
                        size: self.parent.height, self.parent.height
                        on_release: root.get_new_name()
                    MyIconButton:
                        text: 'Save'
                        icon: 'content-save'
                        style: 'text'
                        size: self.parent.height, self.parent.height
                        on_release: root.save_dictionary()
                    MyIconButton:
                        text: 'Delete'
                        icon: 'delete'
                        style: 'text'
                        size: self.parent.height, self.parent.height
                        on_release: root.delete_dictionary()


<CommonAssistChip@MDChip>
    text: ""
    icon: ""
    type: "filter"
    radius: 20
    theme_elevation_level: "Custom"
    elevation_level: 1
    theme_shadow_softness: "Custom"
    shadow_softness: 2
    # MDChipLeadingIcon:
        # icon: root.icon
    MDChipText:
        text: root.text
        role: 'small'
    # MDChipTrailingIcon:
    #     icon: root.icon
                        