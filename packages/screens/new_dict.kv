<DictionaryNew>:
    MDStackLayout: 
        padding: 50,50,50,0
        spacing: 20
        TitleLabel:
            text: f"Create New Dictionary"
        MDBoxLayout:
            radius: 20
            md_bg_color: app.theme_cls.surfaceBrightColor
            orientation: 'vertical'
            size_hint_x: 1
            adaptive_height: True
            padding: 20,20,20,20
            spacing: 50
            EntryField:
                id: name_entry
                hint: "Choose a name"
                role: "medium"
                # text: root.dict_name
                is_correct: root.check_name
            MDBoxLayout:
                adaptive_height: True
                spacing: 20
                Widget:
                MyIconTextButton:
                    text: "Add"
                    icon: "plus"    
                    style: "elevated"
                    on_press: root.confirm()
