<Home>: #MyScreen
    MDAnchorLayout:  
        MDBoxLayout:
            orientation: 'vertical'
            spacing: 50
            size_hint_x: None 
            width: 700+2*(140)
            adaptive_height: True
            RigidIconTextButton:
                text: 'Grammar'
                icon: 'bookshelf'
                style: 'filled'
                font_style: 'Title'
                role: 'medium'
                width: self.parent.width
 
            MDGridLayout:
                id: dictionaries
                rows:1
                cols:3
                adaptive_height: True
                spacing: 20
                RigidIconTextButton:
                    text: 'Dictionaries'
                    icon: 'format-list-text'
                    style: 'filled'
                    font_style: 'Title'
                    role: 'medium'
                    width: 700-2*20
                    on_release: 
                        app.switch_screen("select_dict","left")
                        app.wm.current_screen.directory = app.get_setting('dict_directory')
                        app.wm.current_screen.set_files()
                MyIconButton: 
                    text: "Load Dictionary"
                    icon: 'upload'
                    style: 'filled'
                    padding: 50,50,50,50
                    size:  [140,140]
                    on_release: app.switch_screen("upload_dict","left")
                # Widget:
                MyIconButton: 
                    text: "New Dictionary"
                    icon: 'plus'
                    style: 'filled'
                    padding: 50,50,50,50
                    size:  [140,140]
                    on_release: app.switch_screen("new_dict","left")