<SelectFile>: #MDScreen
    id: "selectfile"
    MDStackLayout: 
        # anchor_y: 'top'
        padding: 50,50,50,0
        spacing: 20
        TitleLabel:
            text: f"Choose an existing dictionary file"
        MDBoxLayout:
            radius: 20
            md_bg_color: app.theme_cls.surfaceBrightColor
            orientation: 'vertical'
            size_hint_x: 1
            adaptive_height: True
            padding: 20,20,20,20
            spacing: 50
            EntryField:
                id: name_entry
                hint: "Choose a name"
                role: "medium"
                text: root.dict_name
                is_correct: root.check_name
            FileOpener:
                id: file_entry
                hint: "Choose a file path"
                role: "small"
                text: root.dict_file
                file_format: root.file_format
                press_button: root.choose # function
                icon: "folder-open"
            EntryFieldWithIcon:
                id: file_format
                hint: "Select the file format"
                role: "medium"
                text: root.file_format
                press_button: root.show_file_formats
                is_correct: root.check_file_format
                icon: 'information'
            MDBoxLayout:
                adaptive_height: True
                spacing: 20
                Widget:
                MyIconTextButton:
                    text: "Add"
                    icon: "plus"    
                    style: "elevated"
                    on_press: root.confirm()

<NameDict>:
    id: "namedict"
    MDStackLayout: 
        padding: 50,50,50,0
        spacing: 20
        TitleLabel:
            text: f"Name the new dictionary"
        MDBoxLayout:
            radius: 20
            md_bg_color: app.theme_cls.surfaceBrightColor
            orientation: 'vertical'
            size_hint_x: 1
            adaptive_height: True
            padding: 20,20,20,20
            spacing: 50
            EntryField:
                id: name_entry
                hint: "Choose a name"
                role: "medium"
                # text: root.dict_name
                is_correct: root.check_name
            MDBoxLayout:
                adaptive_height: True
                spacing: 20
                Widget:
                MyIconTextButton:
                    text: "Add"
                    icon: "plus"    
                    style: "elevated"
                    on_press: root.confirm()
