
# = ============================================================== = #
# =                          ICON AND TEXT                         = #
# = ============================================================== = #

<MyIconTextButton>: #MDButton
    radius: 20
    height: self.ids.label.texture_size[1] #based on padding
    MDButtonIcon: 
        pos_hint: {'x': 0,'center_y': 0.5}
        id: icon
        icon: root.icon
        padding: root.padding,root.padding,20,root.padding
    MDButtonText: 
        id: label
        text: root.text
        pos_hint: {'right': 1,'center_y': 0.5}
        padding: 0,root.padding,root.padding+20,root.padding
    
<RigidIconTextButton>: #MyIconTextButton
    theme_width: "Custom"

<MultiLineIconTextButton>: #MyIconTextButton
    theme_width: "Custom" 
    width: (self.ids.icon.texture_size[0]+self.ids.label.texture_size[0])

# = ============================================================== = #
# =                            ONLY TEXT                           = #
# = ============================================================== = #

<MyTextButton>: #MDButton
    radius: 20
    height: self.ids.label.texture_size[1]
    MDButtonText:
        id: label
        text: root.text
        pos_hint: {'center_x': 0.5,'center_y': 0.5}
        adaptive_width: True
        padding: root.padding

<RigidTextButton>: #MyTextButton
    theme_width: "Custom"

<FlexTextButton>: #MyTextButton
    theme_width: "Custom"
    width: self.ids.label.texture_size[0]

<NavigationButton>:  #MDButton
    radius: 20
    theme_width: "Custom"
    size_hint_x: 1
    style: 'text'
    MDButtonIcon: 
        icon: root.icon
    MDButtonText: 
        text: root.text
        role: 'large'
        padding: 50

# <RectangularIconButtton>: #MDIconButton
#     ripple_effect: False
