
<TableRow>: #MDBoxLayout
    orientation: "horizontal"
    adaptive_height: True
    MDLabel:
        name: "head"
        size_hint_x: None
        width: root.head_width
        text: root.head
        role: root.role
    MDLabel:
        adaptive_width: True
        text: root.content
        role: root.role
        pos_hint: {"x":0}



# = ============================================================== = #
# =                 LIST ITEM WITH BUTTON BEHAVIOR                 = #
# = ============================================================== = #

<FileFormatItem@FlexTextButton>:
    on_release: 
        app.wm.current_screen.select_file_format(self.text)
        app.dismiss_dialog()

<CategoryItem@FlexTextButton>:
    on_release: app.wm.current_screen.edit_property(self.text)

<SortingKeyItem@FlexTextButton>:
    on_release: 
        app.wm.current_screen.sort_dictionary(self.text)
        app.dismiss_dialog()


<ThemeItem@FlexTextButton>: 
    on_release: 
        app.apply_styles(self.text)
        # app.dismiss_dialog()
    md_bg_color: app.theme_cls.surfaceBrightColor

<CustomListItem>: # MDBoxLayout ... 
    radius: 20
    padding: 20
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.surfaceBrightColor

<MultiLineItem>:
    md_bg_color: app.theme_cls.surfaceBrightColor
    radius: 20
    padding: 20,20,20,20
    role: 'small'
    adaptive_height: True

# MultiLineItem
# CustomListItem        
<DirectoryItem>: #MultiLineItem 
    theme_font_size: 'Custom'
    font_size: sp(9)
    on_release: 
        app.wm.current_screen.set_directory(root.setting,root.text)
        app.dismiss_dialog()

<FileItem@MultiLineItem>: #CustomListItem
    on_release: 
        app.wm.current_screen.select(root.text)
        app.dismiss_dialog()

<PaletteItem>: #CustomListItem
    padding: 20,0,20,0
    on_release: 
        app.apply_palette(self.text)
        # app.dismiss_dialog()

    MDLabel:
        id: label
        text: root.text
        role: 'small'
    MDGridLayout:
        radius: 20
        cols: 19
        PaletteColor:
            md_bg_color: root.color_onea
        PaletteColor:
            md_bg_color: root.color_oneb
        PaletteColor:
            md_bg_color: root.color_onec
        PaletteColor:
            md_bg_color: root.color_oned
        PaletteColor:
            md_bg_color: root.color_onee
        PaletteColor:
            md_bg_color: root.color_onef
        PaletteColor:
            md_bg_color: root.color_oneg   
        PaletteColor:
            md_bg_color: root.color_twoa
        PaletteColor:
            md_bg_color: root.color_twob
        PaletteColor:
            md_bg_color: root.color_twoc
        PaletteColor:
            md_bg_color: root.color_twod
        PaletteColor:
            md_bg_color: root.color_twoe
        PaletteColor:
            md_bg_color: root.color_twof
        PaletteColor:
            md_bg_color: root.color_trea
        PaletteColor:
            md_bg_color: root.color_treb
        PaletteColor:
            md_bg_color: root.color_trec
        PaletteColor:
            md_bg_color: root.color_tred
        PaletteColor:
            md_bg_color: root.color_tree
        PaletteColor:
            md_bg_color: root.color_tref

<PaletteColor@MDBoxLayout>:
    theme_bg_color: "Custom" 

<DictionaryItem>: #CustomListItem
    orientation: 'horizontal'
    radius: 20
    spacing: 10
    on_release: root.see_properties()
    MDStackLayout:
        spacing: 10
        MDBoxLayout:
            orientation: 'horizontal'
            spacing: 30
            size_hint: 0.9, None
            height: 50
            ChLabel:
                text: root.char_simp
                role: 'medium'
                max_lines: 1
                adaptive_width: True
            ChLabel:
                text: root.char_trad
                role: 'medium'
                max_lines: 1
                adaptive_width: True
        ChLabel:
            adaptive_height: True
            max_lines: 1
            text: root.char_pron
            role: 'small'
        ChLabel:
            adaptive_height: True
            max_lines: 2
            text: root.translation
            theme_font_size: 'Custom'
            font_size: sp(9)
            theme_line_height: 'Custom'
            line_height: 0.8
    
    
    MDBoxLayout:
        orientation: 'vertical'
        adaptive_width: True
        spacing: 10
        ClickableBoxLayout:
            md_bg_color: app.theme_cls.primaryFixedColor
            radius: 20
            size_hint: None, None
            size: 2*[0] if root.ancient_img=="" else 2*[2*(1.75*60+10   )]
            on_release: root.display_source(root.ancient_img)
            FitImage:
                # source: "./appdata/images/app_icon_fg.png" if not os.path.isfile(root.character_img) else root.character_img
                source: "./appdata/images/app_icon_fg.png" if not os.path.isfile(root.ancient_img) else root.ancient_img
                radius: 20

    EntryInfo: #MDAnchorLayout
        the_size: 60
        padding: 10
        # MDStackLayout:
        MDGridLayout:
            cols:2
            EntryType:
                icon: self.choose_icon(root.has_translation,['','translate'])
                the_size: self.get_size(root.has_translation,[0,60])
            EntryType:
                icon: self.choose_icon(root.is_radical,['alpha-r-box-outline','alpha-r-box'])
                the_size: self.get_size(root.is_radical,[0,60])
            EntryType:
                icon: self.choose_icon(root.is_measure_word,['','scale-unbalanced'])
                the_size: self.get_size(root.is_measure_word,[0,60])
            EntryType:
                icon: self.choose_icon(root.is_grammatical,['','bookshelf'])
                the_size: self.get_size(root.is_grammatical,[0,60])

<EntryType>: #MDIconButton

    size_hint: None, None
    size: self.the_size*1.75, self.the_size*1.75
    font_size: self.the_size
    theme_font_size: 'Custom'
    theme_icon_color: 'Custom'
    icon_color: app.theme_cls.primaryColor
    allow_hover: False
    ripple_effect: False

<EntryInfo>: #MDAnchorLayout
    md_bg_color: app.theme_cls.surfaceDimColor
    radius: 20
    size_hint: None, None
    width: 2*(1.75*self.the_size + self.padding[0])
    height: 2*(1.75*self.the_size + self.padding[0])

