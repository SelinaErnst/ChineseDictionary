<ViewDict>:
    rv_scroll: rv_scroll
    grid: grid
    MDAnchorLayout:
        padding: 50
        MDBoxLayout:
            orientation: 'vertical'
            spacing: 20
            MyTitleLabel:
                anchor_x: "left"
                text: root.dict_name
                role: 'large'
            MDRecycleView:
                id: rv_scroll
                viewclass: 'DictionaryEntry'
                RecycleBoxLayout:
                    id: grid
                    orientation: "vertical"
                    size_hint: 1, None
                    height: self.minimum_height
                    default_size_hint: 1, None
                    default_height: 2*(1.75*60+10)+2*20
                    spacing: 10
    BottomField:
        # theme_bg_color: 'Custom'
        # md_bg_color: 'red'
        MyTextButton:   
            text: 'Save Dictionary'
            style: 'filled'
            on_release: root.save_dictionary()

<DictionaryEntry>: #CustomListItem
    orientation: 'horizontal'
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.surfaceBrightColor
    radius: 20
    spacing: 10
    padding: 20,20,20,20
    on_release: self.get_categories()
    MDStackLayout:
        spacing: 10
        MDBoxLayout:
            orientation: 'horizontal'
            spacing: 30
            size_hint: 0.9, None
            height: 50
            ChLabel:
                text: root.char_simp
                role: 'medium'
                max_lines: 1
                adaptive_width: True
            ChLabel:
                text: root.char_trad
                role: 'medium'
                max_lines: 1
                adaptive_width: True
        ChLabel:
            adaptive_height: True
            max_lines: 1
            text: root.char_pron
            role: 'small'
        ChLabel:
            adaptive_height: True
            max_lines: 2
            text: root.translation
            theme_font_size: 'Custom'
            font_size: sp(9)
            theme_line_height: 'Custom'
            line_height: 0.8
    
    MDBoxLayout:
        md_bg_color: app.theme_cls.surfaceDimColor
        radius: 20
        size_hint: None, None
        size: 2*[2*(1.75*60+10)] if len(root.char_simp) == 1 else 2*[0]

    EntryInfo: #MDAnchorLayout
        the_size: 60
        padding: 10
        # MDStackLayout:
        MDGridLayout:
            cols:2
            EntryType:
                icon: self.choose_icon(root.has_translation,['','translate'])
                the_size: self.get_size(root.has_translation,[0,60])
            EntryType:
                icon: self.choose_icon(root.is_radical,['alpha-r-box-outline','alpha-r-box'])
                the_size: self.get_size(root.is_radical,[0,60])
            EntryType:
                icon: self.choose_icon(root.is_measure_word,['','scale-unbalanced'])
                the_size: self.get_size(root.is_measure_word,[0,60])
            EntryType:
                icon: self.choose_icon(root.is_grammatical,['','bookshelf'])
                the_size: self.get_size(root.is_grammatical,[0,60])

<EntryType>:
    size_hint: None, None
    size: self.the_size*1.75, self.the_size*1.75
    font_size: self.the_size
    theme_font_size: 'Custom'
    theme_icon_color: 'Custom'
    icon_color: app.theme_cls.primaryColor
    allow_hover: False
    ripple_effect: False

<EntryInfo>: #MDAnchorLayout
    md_bg_color: app.theme_cls.surfaceDimColor
    radius: 20
    size_hint: None, None
    width: 2*(1.75*self.the_size + self.padding[0])
    height: 2*(1.75*self.the_size + self.padding[0])

