
<Settings>: #MyScreen
    MDBoxLayout:
        orientation: 'vertical'
        MDStackLayout:
            # orientation: 'vertical'
            spacing: 50
            padding: 50, 50
            Setting:
                id: theme_style
                hint: 'Theme Style'
                text:  app.theme_cls.theme_style
                support_text: 'Choose light or dark mode.'
                icon: 'information'
                press_button: self.show_options
                options: ['Light', 'Dark']
                icons: ['brightness-5','brightness-2']
                itemclass: 'ThemeItem'
                list_height: 300
            Setting:
                id: palette
                hint: 'Palette'
                text: app.theme_cls.primary_palette
                support_text: 'Choose palette from this list of available options.'
                icon: 'information'
                press_button: self.show_options
                options: self.get_palettes()
                itemclass: 'PaletteItem'
                list_height: root.height * 0.5
            Setting:
                id: app_directory
                hint: 'App Directory'
                text: app.get_setting('app_directory',default=True)
                support_text: 'The app directory is the folder where configuration files are stored. The directory has to exist already. \nREMEMBER: the path has to end with "/" to be recognized as a folder.'
                icon: 'information'
                press_button: self.show_options
                itemclass: 'MyFlexTextButton'
                list_height: 0
            Setting:
                id: import_directory
                hint: 'Import Directory'
                text: app.get_setting('import_directory')
                support_text: 'Help'
                support_text: 'The import directory is the folder where dictionary files are imported from. The directory has to exist already. It is recommended to choose a folder in the app directory. \nREMEMBER: the path has to end with "/" to be recognized as a folder.'
                icon: 'information'
                press_button: self.show_options
                itemclass: 'MyFlexTextButton'
                list_height: 0
        BottomField:
            MyTextButton:   
                text: 'Save Settings'
                style: 'filled'
                on_release: root.save_settings()
            
                    
<PaletteItem>:
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.surfaceBrightColor
    on_release: app.apply_palette(self.text)
    MDLabel:
        id: label
        text: root.text
        role: 'small'
        padding: 20
    MDGridLayout:
        cols: 19
        PaletteColor:
            md_bg_color: root.color_onea
        PaletteColor:
            md_bg_color: root.color_oneb
        PaletteColor:
            md_bg_color: root.color_onec
        PaletteColor:
            md_bg_color: root.color_oned
        PaletteColor:
            md_bg_color: root.color_onee
        PaletteColor:
            md_bg_color: root.color_onef
        PaletteColor:
            md_bg_color: root.color_oneg   
        PaletteColor:
            md_bg_color: root.color_twoa
        PaletteColor:
            md_bg_color: root.color_twob
        PaletteColor:
            md_bg_color: root.color_twoc
        PaletteColor:
            md_bg_color: root.color_twod
        PaletteColor:
            md_bg_color: root.color_twoe
        PaletteColor:
            md_bg_color: root.color_twof
        PaletteColor:
            md_bg_color: root.color_trea
        PaletteColor:
            md_bg_color: root.color_treb
        PaletteColor:
            md_bg_color: root.color_trec
        PaletteColor:
            md_bg_color: root.color_tred
        PaletteColor:
            md_bg_color: root.color_tree
        PaletteColor:
            md_bg_color: root.color_tref
            
<PaletteColor@MDBoxLayout>:
    theme_bg_color: "Custom" 

<ThemeItem@MyIconTextButton>: 
    on_release: app.apply_styles(self.text)
