
<MyIconTextButton>: #MDButton
    radius: 20
    theme_width: "Custom"
    height: self.ids.label.texture_size[1]
    width: (self.ids.icon.texture_size[0]+self.ids.label.texture_size[0])
    MDButtonIcon: 
        pos_hint: {'x': 0,'center_y': 0.5}
        id: icon
        icon: root.icon
        padding: root.padding,root.padding,20,root.padding
    MDButtonText: 
        id: label
        text: root.text
        pos_hint: {'right': 1,'center_y': 0.5}
        padding: 0,root.padding,root.padding+20,root.padding

<NavigationButton>:  #MDButton
    theme_width: "Custom"
    size_hint_x: 1
    style: 'text'
    MDButtonIcon: 
        icon: root.icon
    MDButtonText: 
        text: root.text
        role: 'large'
        padding: 50

<MyTextButton>: #MDButton
    radius: 20
    MDButtonText:
        id: label
        text: root.text
        pos_hint: {'center_x': 0.5,'center_y': 0.5}
        adaptive_width: True
        padding: root.padding

<MyFlexTextButton>:
    theme_width: "Custom"
    height: self.ids.label.texture_size[1]
    width: self.ids.label.texture_size[0]

<RectangularIconButtton>: #MDIconButton
    ripple_effect: False

<CustomListItem>:
    radius: 20

<EntryField>: #MDBoxLayout
    id: label
    font_style: "Label"
    mode: "filled"
    theme_bg_color: 'Custom'
    fill_color_normal: app.theme_cls.surfaceBrightColor
    fill_color_focus: app.theme_cls.surfaceVariantColor
    height: 200
    MDTextFieldHintText:
        text: root.hint

<EntryFieldWithIcon>: #MDBoxLayout
    adaptive_height: True
    padding: 0,0,0,0

    EntryField:
        id: label
        text: root.text
        role: root.role
        hint: root.hint
        is_correct: root.is_correct

    MDIconButton:
        size_hint_y: 1
        size_hint_x: None
        width: self.height
        radius: 0
        allow_hover: False
        ripple_effect: False
        icon: root.icon
        on_release: root.press_button()

<MyLabel@MDLabel>: #MDAnchorLayout
    font_style: "Label"
    role: "medium"
    adaptive_size: True

<MyTitleLabel>: #MDAnchorLayout
    size_hint_y: None
    height: self.ids.label.height
    MDLabel:
        id: label
        text: root.text
        adaptive_size: True
        font_style: "Title"
        role: "medium"

<MyScreen>: #Screen
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.surfaceDimColor
        
<BottomField@MDAnchorLayout>:
    size_hint: 1, None
    height: 250
    anchor_y: 'center'
    theme_bg_color: 'Custom'

<ErrorMsg>:
    radius: 20,20,0,0
    md_bg_color: root.theme_cls.onErrorContainerColor
    orientation: "horizontal"
    MDSnackbarText:
        text: root.error
        theme_text_color: "Custom"
        text_color: root.theme_cls.onErrorColor
        max_lines: 3
        
    MDSnackbarSupportingText: 
        text: root.msg 
        theme_text_color: "Custom"
        text_color: root.theme_cls.onErrorColor
        style: "Label"
        role: "small"
    MDSnackbarCloseButton:
        pos_hint: {"center_x": 0.5}
        icon: "close"
        text_color: root.theme_cls.onErrorColor
        on_release: root.dismiss()

<AttentionMsg>:
    orientation: "horizontal"
    MDSnackbarText:
        text: root.attention
        max_lines: 3
    MDSnackbarSupportingText: 
        text: root.msg 
        style: "Label"
        role: "small"
    MDSnackbarCloseButton:
        pos_hint: {"center_x": 0.5}
        icon: "close"
        on_release: root.dismiss()

<ShowOptions>:
    rv_scroll: rv_scroll
    MDDialogHeadlineText:
        text: root.title 
    MDDialogSupportingText:
        text: root.support_text
        halign: 'left'
    MDDialogContentContainer:
        # orientation: 'vertical'
        # MDDivider:
        MDBoxLayout:
            size_hint: 1, None
            height: root.list_height
            MDRecycleView:
                id: rv_scroll
                viewclass: root.itemclass
                RecycleBoxLayout:
                    orientation: "vertical"
                    size_hint: 1, None
                    height: self.minimum_height
                    default_size_hint: 1, None
                    spacing: 10
    MDDialogButtonContainer:
        Widget:
        MDIconButton:
            icon: "close"
            on_release: root.dismiss()
