
<MyIconTextButton>: #MDButton
    radius: 40
    theme_width: "Custom"
    height: self.ids.label.texture_size[1]
    width: self.ids.icon.texture_size[0]+self.ids.label.texture_size[0]
    MDButtonIcon: 
        pos_hint: {'x': 0,'center_y': 0.5}
        id: icon
        icon: root.icon
        padding: root.padding,root.padding,20,root.padding
    MDButtonText: 
        id: label
        text: root.text
        pos_hint: {'right': 1,'center_y': 0.5}
        padding: 0,root.padding,root.padding+20,root.padding

<NavigationButton>:  #MDButton
    theme_width: "Custom"
    size_hint_x: 1
    style: 'text'
    MDButtonIcon: 
        icon: root.icon
    MDButtonText: 
        text: root.text

<MyTextButton>: #MDButton
    radius: 40
    MDButtonText:
        id: label
        text: root.text
        pos_hint: {'center_x': 0.5,'center_y': 0.5}
        adaptive_width: True
        padding: root.padding

<MyFlexTextButton@MyTextButton>:
    theme_width: "Custom"
    height: self.ids.label.texture_size[1]
    width: self.ids.label.texture_size[0]


<RectangularIconButtton>: #MDIconButton
    ripple_effect: False

<EntryField>: #MDBoxLayout
    adaptive_height: True
    padding: 0,0,0,0
    MDTextField:
        id: label
        text: root.text
        font_style: "Label"
        role: root.role
        mode: "filled"
        MDTextFieldHintText:
            text: root.hint

<MyLabel@MDLabel>: #MDAnchorLayout
    font_style: "Label"
    role: "medium"
    adaptive_size: True
    # md_bg_color: app.theme_cls.onErrorColor


<MyTitleLabel>: #MDAnchorLayout
    size_hint_y: None
    height: self.ids.label.height
    MDLabel:
        id: label
        text: root.text
        adaptive_size: True
        font_style: "Title"
        role: "medium"

<MyScreen>: #Screen
    theme_bg_color: "Custom"
    md_bg_color: app.theme_cls.surfaceDimColor
        
<ErrorMsg>:
    md_bg_color: root.theme_cls.onErrorContainerColor
    orientation: "horizontal"
    MDSnackbarText:
        text: root.error
        theme_text_color: "Custom"
        text_color: root.theme_cls.onErrorColor
        max_lines: 3
        
    MDSnackbarSupportingText: 
        text: root.msg 
        theme_text_color: "Custom"
        text_color: root.theme_cls.onErrorColor
        style: "Label"
        role: "small"
    MDSnackbarCloseButton:
        pos_hint: {"center_x": 0.5}
        icon: "close"
        text_color: root.theme_cls.onErrorColor
        on_release: root.dismiss()
