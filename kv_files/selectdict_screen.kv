<SelectFile>: #MDScreen
    id: "selectfile"
    MDAnchorLayout: 
        MDBoxLayout:
            md_bg_color: app.theme_cls.surfaceBrightColor
            orientation: 'vertical'
            size_hint: None,None
            adaptive_height: True
            size: 900,500
            padding: 20
            spacing: 20
            MyTitleLabel:
                text: f"Add a new dictionary"
            FileOpener:
                id: file_entry
                text: root.dict_file
            EntryField:
                id: name_entry
                hint: "Choose a name"
                role: "large"
                text: root.dict_name
            MDBoxLayout:
                adaptive_height: True
                Widget:
                MyIconTextButton:
                    text: "Add"
                    icon: "plus"    
                    on_press: root.confirm()
                    style: "elevated"

<FileOpener>:
    hint: "Choose a file"
    role: "small"
    adaptive_height: True
    padding: 0,0,0,0

    MDTextField:
        id: label
        text: root.text
        font_style: "Label"
        role: root.role
        mode: "filled"
        MDTextFieldHintText:
            text: root.hint
        # MDTextFieldTrailingIcon:
            # id: reload
            # icon: "reload"c
            # theme_font_size: "Custom"
            # font_size: sp(15)

    MDIconButton:
        id: fileopener
        size_hint_y: 1
        size_hint_x: None
        width: self.height
        radius: 0
        allow_hover: False
        ripple_effect: False
        icon: "folder-open"
        on_release: root.choose()

<ReloadButton>:
    icon: "reload"
    theme_font_size: "Custom"
    font_size: sp(10)
    allow_hover: False
    ripple_effect: False
    size_hint_y: 1
    width: self.height*0.4
    on_release: self.parent.update()

<ConfirmChoice>:
    MDDialogHeadlineText:
        text: root.title
    MDDialogSupportingText:
        text: root.msg
        role: "small"
    MDDialogContentContainer:
        orientation: "vertical"
        MDDivider:
        DialogLines:
            head: "dictionary file:"
            MDLabel:
                adaptive_width: True
                text: root.file_name
                role: "small"
                pos_hint: {"x":0}
        DialogLines:
            head: "dictionary name:"
            MDLabel:
                adaptive_width: True
                text: root.dict_name
                role: "small"
                pos_hint: {"x":0}
        DialogLines:
            head: "number of entries:"
            MDLabel:
                adaptive_width: True
                text: root.count
                role: "small"
                pos_hint: {"x":0}
        # DialogLines:
        #     head: "first line:"
        #     MDScrollView:
        #         do_scroll_x: False
        #         ChLabel:
        #             text: root.first_line
        #             size_hint_y: None
        #             height: self.texture_size[1]
        #             text_size: self.width, None
        #             theme_font_size: "Custom"
        #             font_size: sp(7)
        MDDivider:
    MDDialogButtonContainer:
        Widget:
        MyIconTextButton:
            icon: "close"
            text: "No"
            style: "text"
            on_release: root.dismiss()
        Widget:
        MyIconTextButton:
            icon: "check"
            text: "Yes"
            style: "text"
            on_release: 
                app.wm.current_screen.continue_on()
                root.dismiss()
        Widget:


<DialogLines@MDBoxLayout>:
    orientation: "horizontal"
    adaptive_height: True
    spacing: 30
    MDLabel:
        name: "head"
        adaptive_width: True
        text: root.head
        role: "small"
    