<SelectFile>: #MDScreen
    id: "selectfile"
    MDAnchorLayout: 
        anchor_y: 'top'
        padding: 50,50,50,0
        MDBoxLayout:
            radius: 20
            md_bg_color: app.theme_cls.surfaceBrightColor
            orientation: 'vertical'
            size_hint_x: 1
            adaptive_height: True
            # size: 900,500
            padding: 20,50,20,20
            spacing: 50
            MyTitleLabel:
                text: f"Open a dictionary"
            EntryField:
                id: name_entry
                hint: "Choose a name"
                role: "medium"
                text: root.dict_name
                is_correct: root.check_name
            FileOpener:
                id: file_entry
                hint: "Choose a file"
                role: "small"
                text: root.dict_file
                file_format: root.file_format
                press_button: self.choose # function
                icon: "folder-open"
            EntryFieldWithIcon:
                id: file_format
                hint: "File format"
                role: "medium"
                text: root.file_format
                press_button: root.show_file_formats
                is_correct: root.check_file_format
                icon: 'information'
            MDBoxLayout:
                adaptive_height: True
                spacing: 20
                Widget:
                MyIconTextButton:
                    text: "Add"
                    icon: "plus"    
                    on_press: root.confirm()
                    style: "elevated"
                    radius: 20

<ConfirmChoice>: #MDDialog
    MDDialogHeadlineText:
        text: root.title
    MDDialogSupportingText:
        text: root.msg
        role: "small"
    MDDialogContentContainer:
        orientation: "vertical"
        MDDivider:
        DialogLines:
            head: "File"
            MDLabel:
                adaptive_width: True
                text: root.file_name
                role: "small"
                pos_hint: {"x":0}
        DialogLines:
            head: "Format"
            MDLabel:
                adaptive_width: True
                text: root.file_format
                role: "small"
                pos_hint: {"x":0}
        DialogLines:
            head: "Name"
            MDLabel:
                adaptive_width: True
                text: root.dict_name
                role: "small"
                pos_hint: {"x":0}
        DialogLines:
            head: "Entries"
            MDLabel:
                adaptive_width: True
                text: root.count
                role: "small"
                pos_hint: {"x":0}
        MDDivider:
        ChLabel:
            text: root.first_line
            theme_font_size: 'Custom'
            font_size: sp(9)
            shorten: True
            valign: 'center'
            adaptive_height: True
            padding: 20,20,0,0

    MDDialogButtonContainer:
        Widget:
        MyIconTextButton:
            icon: "close"
            text: "No"
            style: "text"
            on_release: root.dismiss()
        Widget:
        MyIconTextButton:
            icon: "check"
            text: "Yes"
            style: "text"
            on_release: 
                app.wm.current_screen.continue_on()
                root.dismiss()
        Widget:

<DialogLines>:
    orientation: "horizontal"
    adaptive_height: True
    spacing: 30
    MDLabel:
        name: "head"
        # adaptive_width: True
        size_hint_x: None
        width: 200
        text: root.head
        role: "small"

<FileFormatItem@MyFlexTextButton>:
    on_release: app.wm.current_screen.select_file_format(self.text)
        