# = ============================================================== = #
# =                             SCREEN                             = #
# = ============================================================== = #


<Interface>:
    wm: wm.__self__
    orientation: 'vertical'
    
    MDTopAppBar:
        type: 'small'
        theme_bg_color: "Custom"
        md_bg_color: app.theme_cls.surfaceBrightColor
        size_hint_y: None
        height: 150
        MDTopAppBarLeadingButtonContainer:
            MDActionTopAppBarButton:
                icon: "menu"
                size_hint: None, None
                size: 120, 120
                on_release: nav_drawer.set_state("toggle")
                
        MDTopAppBarTitle:
            text: "Chinese Dictionary"
            halign: "center"
            role: 'medium'
            
        MDTopAppBarTrailingButtonContainer:
            MDActionTopAppBarButton:
                icon: "dots-vertical"
                size_hint: None, None
                size: 120, 120

    MDNavigationLayout:
        WindowManager:
            id: wm
            
        MDNavigationDrawer:
            id: nav_drawer
            radius: 0, 16, 16, 0
            MDNavigationDrawerMenu:
                spacing: 5
                MDNavigationDrawerLabel:
                    text: "Menu"
                MDNavigationDrawerDivider:
                NavigationButton:
                    on_release:
                        app.previous_screen()
                        nav_drawer.set_state("toggle")
                    icon: "arrow-left"
                    text: "Go Back"
                NavigationButton:
                    on_release: 
                        app.switch_screen('home','down')
                        nav_drawer.set_state("toggle")
                    icon: "home"
                    text: "Home"
                NavigationButton:
                    on_release: 
                        app.switch_screen('settings','down')
                        nav_drawer.set_state("toggle")
                    icon: "cog-outline"
                    text: "Settings"
                MDNavigationDrawerDivider:
                NavigationButton:
                    on_release: 
                        app._show_validation_dialog()
                        nav_drawer.set_state("toggle")
                    icon: "account-check"
                    text: "Access"

<ViewDict>:
    rv_scroll: rv_scroll
    grid: grid
    MDAnchorLayout:
        padding: 50
        MDBoxLayout:
            orientation: 'vertical'
            spacing: 20
            TitleLabel:
                anchor_x: "left"
                text: root.dict_name
                role: 'large'
            MDRecycleView:
                id: rv_scroll
                viewclass: 'DictionaryItem'
                RecycleBoxLayout:
                    id: grid
                    orientation: "vertical"
                    size_hint: 1, None
                    height: self.minimum_height
                    default_size_hint: 1, None
                    default_height: 2*(1.75*60+10)+2*20
                    spacing: 10
    BottomFieldButton:
        text: 'Save Dictionary'
        style: 'filled'
        press_button: root.save_dictionary

<SelectFile>: #MDScreen
    id: "selectfile"
    MDStackLayout: 
        # anchor_y: 'top'
        padding: 50,50,50,0
        spacing: 20
        TitleLabel:
            text: f"Choose a dictionary file"
        MDBoxLayout:
            radius: 20
            md_bg_color: app.theme_cls.surfaceBrightColor
            orientation: 'vertical'
            size_hint_x: 1
            adaptive_height: True
            padding: 20,20,20,20
            spacing: 50
            EntryField:
                id: name_entry
                hint: "Choose a name"
                role: "medium"
                text: root.dict_name
                is_correct: root.check_name
            FileOpener:
                id: file_entry
                hint: "Choose a file path"
                role: "small"
                text: root.dict_file
                file_format: root.file_format
                press_button: self.choose # function
                icon: "folder-open"
            EntryFieldWithIcon:
                id: file_format
                hint: "Select the file format"
                role: "medium"
                text: root.file_format
                press_button: root.show_file_formats
                is_correct: root.check_file_format
                icon: 'information'
            MDBoxLayout:
                adaptive_height: True
                spacing: 20
                Widget:
                MyIconTextButton:
                    text: "Add"
                    icon: "plus"    
                    style: "elevated"
                    on_press: root.confirm()

<FileChooser>:
    id: "filechooser"
    rv_scroll: rv_scroll
    grid: grid
    MDAnchorLayout:
        padding: 50
        MDBoxLayout:
            orientation: 'vertical'
            spacing: 20
            TitleLabel:
                anchor_x: "left"
                text: "Select a file"
            MultiLineLabel:
                anchor_x: "left"
                text: "format:     "+root.file_format
                md_bg_color: app.theme_cls.primaryContainerColor
            MultiLineLabel:
                anchor_x: "left"
                text: "directory:  "+root.directory
                md_bg_color: app.theme_cls.primaryContainerColor
                role: 'small'
            MDRecycleView:
                id: rv_scroll
                viewclass: 'FileItem'
                RecycleBoxLayout:
                    id: grid
                    orientation: "vertical"
                    size_hint: 1, None
                    height: self.minimum_height
                    default_size_hint: 1, None
                    spacing: 10
            MDBoxLayout:
                adaptive_height: True
                orientation: "horizontal"
                Widget:
                MDIconButton:
                    icon: "reload"
                    on_release: root.update()
                    allow_hover: False
                    ripple_effect: False

<Settings>: #MyScreen
    MDBoxLayout:
        orientation: 'vertical'
        MDStackLayout:
            # orientation: 'vertical'
            spacing: 50
            padding: 50, 50
            Setting:
                id: theme_style
                hint: 'Theme Style'
                text:  app.theme_cls.theme_style
                support_text: 'Choose light or dark mode.'
                icon: 'theme-light-dark'
                press_button: self.show_options
                options: ['Light', 'Dark']
                icons: ['brightness-5','brightness-2']
                itemclass: 'ThemeItem'
                list_height: 300
            Setting:
                id: palette
                hint: 'Palette'
                text:  app.theme_cls.primary_palette
                support_text: 'Choose palette from this list of available options.'
                icon: 'palette'
                press_button: self.show_options
                options: self.get_palettes()
                itemclass: 'PaletteItem'
                list_height: root.height * 0.5
            Setting:
                id: app_directory
                setting: 'app_directory'
                hint: 'App Directory'
                text: root.get_app_directory()
                support_text: 'The app directory is the folder where configuration files are stored. The directory has to exist already. \nREMEMBER: the path has to end with "/" to be recognized as a folder.'
                icon: 'folder-open'
                press_button: self.show_options
                options: app.app_dir_example
                itemclass: 'DirectoryItem'
                list_height: 300
            Setting:
                id: import_directory
                setting: 'import_directory'
                hint: 'Import Directory'
                text: root.get_import_directory()
                support_text: 'The import directory is the folder where dictionary files are imported from. The directory has to exist already. It is recommended to choose a folder in the app directory. \nREMEMBER: the path has to end with "/" to be recognized as a folder.'
                icon: 'folder-open'
                press_button: self.show_options
                options: app.import_dir_example
                itemclass: 'DirectoryItem'
                list_height: 300
        BottomFieldButton:
            text: 'Save Settings'
            style: 'filled'
            press_button: root.save_settings

